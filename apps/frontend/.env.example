# =============================================================================
# Vite dev server
# =============================================================================
VITE_DEV_PORT=3000

# =============================================================================
# Backend API (direct — no Vite proxy)
# Production build: leave unset or empty for same-origin /api via nginx.
# =============================================================================
VITE_BASE_URL_BACKEND=http://localhost:3080

# =============================================================================
# Default connection panel (WebSocket)
# =============================================================================
VITE_WS_HOST=localhost
VITE_WS_PORT=3080
VITE_DEFAULT_CHANNEL=automation-default
