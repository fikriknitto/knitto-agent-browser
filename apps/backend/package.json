    "typecheck": "tsc --noEmit",
    "start": "node -r dotenv/config dist/server.js"
  },
  "dependencies": {
    "@connectrpc/connect-node": "^1.6.1",
    "@cursor/sdk": "^1.0.19",
    "@google/genai": "^2.8.0",
    "@knitto/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "puppeteer": "^24.8.2",
    "puppeteer-screen-recorder": "^3.0.6",
    "ws": "^8.18.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
