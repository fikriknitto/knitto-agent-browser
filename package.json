{
  "name": "knitto-browser-agent",
  "version": "1.0.0",
  "description": "Knitto Browser Agent — frontend + backend monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "concurrently -n shared,backend,frontend -c cyan,green \"pnpm dev:shared\" \"pnpm dev:backend\" \"pnpm dev:frontend\"  ",
    "dev:frontend": "pnpm --filter @knitto/frontend dev",
    "dev:backend": "pnpm --filter @knitto/backend dev",
    "dev:shared": "pnpm --filter @knitto/shared prepare",
    "build": "pnpm build:shared && pnpm build:backend && pnpm build:frontend",
    "build:shared": "pnpm --filter @knitto/shared build",
    "build:backend": "pnpm --filter @knitto/backend build",
    "build:frontend": "pnpm --filter @knitto/frontend build",
    "typecheck": "pnpm -r typecheck",
    "start": "pnpm --filter @knitto/backend start",
    "preview": "pnpm --filter @knitto/frontend preview",
    "clean": "pnpm -r exec node -e \"try{require('fs').rmSync('dist',{recursive:true,force:true})}catch{}\""
  },
  "keywords": [
    "knitto",
    "browser",
    "agent",
    "puppeteer",
    "monorepo"
  ],
  "author": "knittotextile",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
