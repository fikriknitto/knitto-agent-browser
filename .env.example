# =============================================================================
# AI providers
# =============================================================================
GEMINI_API_KEY=
CURSOR_API_KEY=

# =============================================================================
# Bridge (Gemini / Cursor / 9Router)
# =============================================================================
# Default model per bridge (Gemini: gemini-2.5-flash | Cursor: composer-2.5)
KNITTO_BRIDGE_MODEL=gemini-2.5-flash

# Working directory saat agent Cursor/SDK jalan (kosong = folder temp sistem)
KNITTO_BRIDGE_CWD=

# Job queue & agent loop
KNITTO_BRIDGE_MAX_CONCURRENT=1
KNITTO_BRIDGE_JOB_TIMEOUT_MS=600000
KNITTO_BRIDGE_MAX_TOOL_CALLS=40

# =============================================================================
# WebSocket relay (socket server + bridge clients + Web UI)
# =============================================================================
AUTOMATION_WS_HOST=0.0.0.0
AUTOMATION_WS_PORT=3077
AUTOMATION_WS_SERVER=localhost
# true | 1 = wss:// (production); false = ws://
AUTOMATION_WS_TLS=false

# =============================================================================
# MCP Puppeteer server (spawned by bridge)
# =============================================================================
# Path ke src/mcp/index.ts (kosong = auto dari repo)
AUTOMATION_MCP_PATH=

# =============================================================================
# Browser / Puppeteer
# =============================================================================
# false = headed (browser terlihat), true = headless
AUTOMATION_HEADLESS=false
AUTOMATION_SLOW_MO_MS=0
AUTOMATION_BROWSER_TIMEOUT_MS=30000
AUTOMATION_VIEWPORT_WIDTH=1280
AUTOMATION_VIEWPORT_HEIGHT=720

# =============================================================================
# Storage (default: folder memory/ dan screenshoot/ di root project)
# =============================================================================
AUTOMATION_MEMORY_DIR=
AUTOMATION_SCREENSHOT_DIR=

# =============================================================================
# 9Router (pnpm run start:bridge:ninerouter)
# =============================================================================
NINEROUTER_BASE_URL=http://localhost:20128
NINEROUTER_API_KEY=
# Kosong = pakai KNITTO_BRIDGE_MODEL
NINEROUTER_MODEL=
NINEROUTER_MAX_RETRIES=5
NINEROUTER_RETRY_DELAY_MS=2000

# =============================================================================
# Logging (debug | info | warn | error)
# =============================================================================
KNITTO_MCP_LOG_LEVEL=info
